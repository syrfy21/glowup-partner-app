rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isCoupleMember(coupleId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberIds;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;

      match /devices/{deviceId} {
        allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
      }
    }

    match /inviteCodes/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if false;
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /couples/{coupleId} {
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == 1;

      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;

      allow update: if signedIn() && (
        request.auth.uid in resource.data.memberIds ||
        (
          resource.data.memberIds.size() < 2 &&
          request.auth.uid in request.resource.data.memberIds &&
          resource.data.memberIds[0] in request.resource.data.memberIds &&
          request.resource.data.memberIds.size() == 2
        )
      );

      allow delete: if false;

      match /{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
    }
  }
}
